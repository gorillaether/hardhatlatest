{
    "compilerOptions": {
      "target": "ES2022",
      "module": "commonjs",
      "declaration": true,
      "strict": true,
      "moduleResolution": "node",
      "allowSyntheticDefaultImports": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true
    },
    "include": [
      "./hardhat.config.ts",
      "./ignition/**/*",
      "./contracts/**/*",
      "./test/**/*",
      "./typechain-types/**/*"
    ],
    "exclude": [
      "node_modules"
    ]
  }